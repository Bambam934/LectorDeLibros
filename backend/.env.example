PORT=3000
HOST=127.0.0.1
NODE_ENV=development

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lectorsync
JWT_SECRET=replace_me_change_in_production_minimum_32_chars

RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=15 minute

CORS_ORIGINS=http://localhost:3000,https://tu-dominio.com

HELMET_ENABLED=1

# NVIDIA NIM API (GLM-5.1)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
